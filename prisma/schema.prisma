generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [uuidOssp(map: "uuid-ossp"), pgTrgm(map: "pg_trgm"), pgVector(map: "vector", schema: "public")]
}

// ╔══════════════════════════════════════════════════════════════╗
// ║                          ENUMS                              ║
// ╚══════════════════════════════════════════════════════════════╝

enum UserRole {
  ADMIN
  STUDENT
}

enum EmailTokenType {
  VERIFICATION
  PASSWORD_RESET
}

enum TariffTier {
  BASIC
  STANDARD
  PARTNER
}

enum TariffFeatureType {
  KNOWLEDGE_BASE_ACCESS
  AI_CHAT_ACCESS
}

enum PromoCodeType {
  PERCENT
  FIXED
  FULL_ACCESS
}

enum PurchaseStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum PurchaseItemType {
  COURSE
  TARIFF
}

enum PaymentMethod {
  MANUAL
  CARD
  INVOICE
}

enum AccessResourceType {
  COURSE
  KNOWLEDGE_BASE
  AI_CHAT
}

enum AccessGrantSource {
  PURCHASE
  ADMIN_GRANT
  PROMO_CODE
}

enum LessonType {
  VIDEO
  TEXT
  MIXED
}

enum AssignmentType {
  TEXT
  FILE_UPLOAD
  TEST
}

enum SubmissionStatus {
  PENDING
  AI_REVIEWED
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum KnowledgeItemType {
  DOCUMENT
  TEMPLATE
  WEBINAR_RECORDING
}

enum WebinarStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum AiMessageRole {
  USER
  ASSISTANT
}

enum AiConfidenceLevel {
  HIGH
  MEDIUM
  LOW
  NONE
}

enum AiEmbeddingSourceType {
  LESSON
  KNOWLEDGE_ITEM
}

enum NotificationType {
  REGISTRATION
  EMAIL_VERIFICATION
  PASSWORD_RESET
  PURCHASE_CONFIRMED
  ACCESS_GRANTED
  ACCESS_REVOKED
  WEBINAR_REMINDER
  WEBINAR_STARTED
  AUTO_WEBINAR_REMINDER
  AUTO_WEBINAR_STARTED
  ASSIGNMENT_REVIEWED
  NEW_COURSE
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  TELEGRAM
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
}

enum PartnerEventType {
  REGISTRATION
  PURCHASE
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

// ╔══════════════════════════════════════════════════════════════╗
// ║                  1. AUTH & USERS  (5 таблиц)                ║
// ╚══════════════════════════════════════════════════════════════╝

/// Пользователь: identity + профиль.
///
/// isPartner УДАЛЁН — source of truth: partner_profiles.is_approved.
/// referred_by_id УДАЛЁН — source of truth: partner_referrals (event=REGISTRATION).
/// В JWT isPartner вычисляется при логине из partner_profiles.
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  phone         String?
  avatarPath    String?  @map("avatar_path")
  role          UserRole @default(STUDENT)
  isActive      Boolean  @default(true) @map("is_active")
  emailVerified Boolean  @default(false) @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessions               Session[]
  emailTokens            EmailToken[]
  accessGrants           AccessGrant[]
  purchases              Purchase[]
  courseProgresses        CourseProgress[]
  lessonProgresses       LessonProgress[]
  assignmentSubmissions  AssignmentSubmission[]
  webinarAttendances     WebinarAttendance[]
  webinarMessages        WebinarChatMessage[]
  autoWebinarViews       AutoWebinarView[]
  aiChatSessions         AiChatSession[]
  notifications          Notification[]
  telegramLink           TelegramLink?
  promoCodeUsages        PromoCodeUsage[]
  partnerProfile         PartnerProfile?
  referredByEntries      PartnerReferral[] @relation("ReferredUser")

  @@map("users")
}

/// Сессия (refresh token).
/// tokenDigest = SHA-256 от реального токена. Raw-значение в БД НЕ хранится.
/// Lookup: hash(incoming_token) → find by digest.
model Session {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  tokenDigest String   @unique @map("token_digest")
  userAgent   String?  @map("user_agent")
  ipAddress   String?  @map("ip_address")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

/// Токен подтверждения email / сброса пароля.
/// tokenDigest = SHA-256 от реального токена. В БД хранится только digest.
model EmailToken {
  id          String         @id @default(uuid())
  userId      String         @map("user_id")
  tokenDigest String         @unique @map("token_digest")
  type        EmailTokenType
  expiresAt   DateTime       @map("expires_at")
  usedAt      DateTime?      @map("used_at")
  createdAt   DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("email_tokens")
}

/// Привязка Telegram для уведомлений. 1 user : 1 telegram.
model TelegramLink {
  id       String   @id @default(uuid())
  userId   String   @unique @map("user_id")
  chatId   String   @unique @map("chat_id")
  username String?
  isActive Boolean  @default(true) @map("is_active")
  linkedAt DateTime @default(now()) @map("linked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_links")
}

/// Лог безопасности. Append-only.
model SecurityLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("security_logs")
}

// ╔══════════════════════════════════════════════════════════════╗
// ║              2. TARIFFS & ENTITLEMENTS  (3 таблицы)          ║
// ╚══════════════════════════════════════════════════════════════╝

/// Тариф: набор курсов + глобальные фичи (KB, AI).
model Tariff {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  tier        TariffTier
  description String?
  price       Decimal    @db.Decimal(10, 2)
  currency    String     @default("RUB")
  isActive    Boolean    @default(true) @map("is_active")
  sortOrder   Int        @default(0) @map("sort_order")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  tariffCourses  TariffCourse[]
  tariffFeatures TariffFeature[]
  purchaseItems  PurchaseItem[]
  accessGrants   AccessGrant[]
  promoCodes     PromoCode[]

  @@map("tariffs")
}

/// Связь тариф ↔ курс.
model TariffCourse {
  id       String @id @default(uuid())
  tariffId String @map("tariff_id")
  courseId  String @map("course_id")

  tariff Tariff @relation(fields: [tariffId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([tariffId, courseId])
  @@map("tariff_courses")
}

/// Глобальные фичи тарифа.
/// config JSON: AI → {"dailyLimit":30,"monthlyLimit":500}; KB → {} (флаг).
model TariffFeature {
  id       String            @id @default(uuid())
  tariffId String            @map("tariff_id")
  feature  TariffFeatureType
  config   Json?

  tariff Tariff @relation(fields: [tariffId], references: [id], onDelete: Cascade)

  @@unique([tariffId, feature])
  @@map("tariff_features")
}

// ╔══════════════════════════════════════════════════════════════╗
// ║                 3. PROMO CODES  (2 таблицы)                 ║
// ╚══════════════════════════════════════════════════════════════╝

/// Промокод. FK на tariff/course — ссылочная целостность на уровне БД.
/// Оба NULL → промокод универсальный.
/// onDelete: Restrict — нельзя hard-delete курс/тариф, пока есть привязанные промокоды.
/// Политика: курсы/тарифы архивируются (isPublished/isActive=false), не удаляются.
/// App-layer при применении проверяет, что target активен/опубликован.
model PromoCode {
  id            String        @id @default(uuid())
  code          String        @unique
  type          PromoCodeType
  value         Decimal       @db.Decimal(10, 2)
  maxUsages     Int?          @map("max_usages")
  currentUsages Int           @default(0) @map("current_usages")
  validFrom     DateTime?     @map("valid_from")
  validUntil    DateTime?     @map("valid_until")
  isActive      Boolean       @default(true) @map("is_active")
  tariffId      String?       @map("tariff_id")
  courseId       String?      @map("course_id")
  createdAt     DateTime      @default(now()) @map("created_at")

  targetTariff Tariff? @relation(fields: [tariffId], references: [id], onDelete: Restrict)
  targetCourse Course? @relation(fields: [courseId], references: [id], onDelete: Restrict)
  usages       PromoCodeUsage[]

  @@map("promo_codes")
}

/// Использование промокода.
model PromoCodeUsage {
  id          String   @id @default(uuid())
  promoCodeId String   @map("promo_code_id")
  userId      String   @map("user_id")
  purchaseId  String?  @map("purchase_id")
  usedAt      DateTime @default(now()) @map("used_at")

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  purchase  Purchase? @relation(fields: [purchaseId], references: [id])

  @@unique([promoCodeId, userId])
  @@map("promo_code_usages")
}

// ╔══════════════════════════════════════════════════════════════╗
// ║              4. PURCHASES & BILLING  (3 таблицы)            ║
// ╚══════════════════════════════════════════════════════════════╝

/// Покупка. MVP: админ подтверждает вручную.
model Purchase {
  id             String         @id @default(uuid())
  userId         String         @map("user_id")
  status         PurchaseStatus @default(PENDING)
  totalAmount    Decimal        @db.Decimal(10, 2) @map("total_amount")
  discountAmount Decimal        @default(0) @db.Decimal(10, 2) @map("discount_amount")
  finalAmount    Decimal        @db.Decimal(10, 2) @map("final_amount")
  currency       String         @default("RUB")
  paymentMethod  PaymentMethod  @default(MANUAL) @map("payment_method")
  promoCodeId    String?        @map("promo_code_id")
  confirmedAt    DateTime?      @map("confirmed_at")
  confirmedBy    String?        @map("confirmed_by")
  cancelledAt    DateTime?      @map("cancelled_at")
  cancelledBy    String?        @map("cancelled_by")
  cancelReason   String?        @map("cancel_reason")
  note           String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user            User              @relation(fields: [userId], references: [id])
  items           PurchaseItem[]
  accessGrants    AccessGrant[]
  billingRecords  BillingRecord[]
  promoCodeUsages PromoCodeUsage[]
  commissions     PartnerCommission[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("purchases")
}

/// Позиция покупки. title/price — snapshot на момент покупки.
model PurchaseItem {
  id         String           @id @default(uuid())
  purchaseId String           @map("purchase_id")
  itemType   PurchaseItemType @map("item_type")
  courseId    String?          @map("course_id")
  tariffId   String?          @map("tariff_id")
  price      Decimal          @db.Decimal(10, 2)
  title      String

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  course   Course?  @relation(fields: [courseId], references: [id])
  tariff   Tariff?  @relation(fields: [tariffId], references: [id])

  @@index([purchaseId])
  @@map("purchase_items")
}

/// Финансовая запись. Создаётся при подтверждении покупки.
model BillingRecord {
  id            String   @id @default(uuid())
  purchaseId    String   @map("purchase_id")
  amount        Decimal  @db.Decimal(10, 2)
  currency      String   @default("RUB")
  description   String
  invoiceNumber String?  @map("invoice_number")
  createdAt     DateTime @default(now()) @map("created_at")

  purchase Purchase @relation(fields: [purchaseId], references: [id])

  @@index([purchaseId])
  @@index([createdAt])
  @@map("billing_records")
}

// ╔══════════════════════════════════════════════════════════════╗
// ║                5. ACCESS GRANTS  (1 таблица)                ║
// ╚══════════════════════════════════════════════════════════════╝

/// Центральная сущность access-first модели.
///
/// Гранулярность:
///   COURSE         → resource_id = courseId (required)
///   KNOWLEDGE_BASE → resource_id = NULL
///   AI_CHAT        → resource_id = NULL
///
/// tier: заполняется для KNOWLEDGE_BASE (tier-based KB filtering).
///       Для COURSE и AI_CHAT — NULL.
///
/// Защита от дублей — два partial unique index (raw SQL migration):
///   1. (user_id, resource_type, resource_id) WHERE is_active AND resource_id IS NOT NULL — COURSE
///   2. (user_id, resource_type)              WHERE is_active AND resource_id IS NULL     — KB, AI_CHAT
/// CHECK constraint: COURSE requires resource_id NOT NULL (raw SQL migration).
model AccessGrant {
  id              String             @id @default(uuid())
  userId          String             @map("user_id")
  resourceType    AccessResourceType @map("resource_type")
  resourceId      String?            @map("resource_id")
  grantedVia      AccessGrantSource  @map("granted_via")
  purchaseId      String?            @map("purchase_id")
  grantedByUserId String?            @map("granted_by_user_id")
  tariffId        String?            @map("tariff_id")
  tier            TariffTier?
  expiresAt       DateTime?          @map("expires_at")
  isActive        Boolean            @default(true) @map("is_active")
  revokedAt       DateTime?          @map("revoked_at")
  revokedBy       String?            @map("revoked_by")
  createdAt       DateTime           @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchase Purchase? @relation(fields: [purchaseId], references: [id])
  tariff   Tariff?   @relation(fields: [tariffId], references: [id])

  @@index([userId, resourceType, resourceId, isActive])
  @@index([userId, resourceType, isActive])
  @@index([purchaseId])
  @@index([expiresAt])
  @@map("access_grants")
}

// ╔══════════════════════════════════════════════════════════════╗
// ║                   6. COURSES  (4 таблицы)                   ║
// ╚══════════════════════════════════════════════════════════════╝

/// Курс. Доступ через AccessGrant(COURSE, courseId).
///
/// Прямая покупка:
///   price != NULL и isDirectPurchaseAvailable = true → можно купить без тарифа.
///   oldPrice — зачёркнутая цена для UI ("было 5000, стало 3000").
model Course {
  id                         String   @id @default(uuid())
  title                      String
  slug                       String   @unique
  description                String?
  coverPath                  String?  @map("cover_path")
  price                      Decimal? @db.Decimal(10, 2)
  oldPrice                   Decimal? @db.Decimal(10, 2) @map("old_price")
  currency                   String   @default("RUB")
  isPublished                Boolean  @default(false) @map("is_published")
  isDirectPurchaseAvailable  Boolean  @default(false) @map("is_direct_purchase_available")
  sortOrder                  Int      @default(0) @map("sort_order")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  modules          Module[]
  tariffCourses    TariffCourse[]
  purchaseItems    PurchaseItem[]
  courseProgresses CourseProgress[]
  webinars         Webinar[]
  autoWebinars     AutoWebinar[]
  promoCodes       PromoCode[]
  aiChatSessions   AiChatSession[]

  @@map("courses")
}

/// Модуль курса.
model Module {
  id        String   @id @default(uuid())
  courseId   String   @map("course_id")
  title     String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
  @@map("modules")
}

/// Урок. Доступ = AccessGrant на курс. isFree=true → без AccessGrant.
model Lesson {
  id                 String     @id @default(uuid())
  moduleId           String     @map("module_id")
  title              String
  type               LessonType @default(MIXED)
  content            String?
  videoPath          String?    @map("video_path")
  videoDuration      Int?       @map("video_duration")
  isFree             Boolean    @default(false) @map("is_free")
  sortOrder          Int        @default(0) @map("sort_order")
  requiresAssignment Boolean    @default(false) @map("requires_assignment")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  module           Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  files            LessonFile[]
  assignments      Assignment[]
  checklists       Checklist[]
  lessonProgresses LessonProgress[]

  @@index([moduleId])
  @@map("lessons")
}

/// Файл урока.
model LessonFile {
  id        String   @id @default(uuid())
  lessonId  String   @map("lesson_id")
  fileName  String   @map("file_name")
  filePath  String   @map("file_path")
  fileSize  Int?     @map("file_size")
  mimeType  String?  @map("mime_type")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("lesson_files")
}

// ╔══════════════════════════════════════════════════════════════╗
// ║                   7. PROGRESS  (2 таблицы)                  ║
// ╚══════════════════════════════════════════════════════════════╝

/// CACHE / AGGREGATE — пересчитывается из lesson_progresses.
/// НЕ source of truth. Source of truth = lesson_progresses.
/// Пересчёт: при каждом complete/uncomplete урока через service.
model CourseProgress {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  courseId            String    @map("course_id")
  completedLessons   Int       @default(0) @map("completed_lessons")
  totalLessons       Int       @default(0) @map("total_lessons")
  progressPercent    Float     @default(0) @map("progress_percent")
  completedAt        DateTime? @map("completed_at")
  lastRecalculatedAt DateTime  @default(now()) @map("last_recalculated_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("course_progresses")
}

/// SOURCE OF TRUTH для прогресса обучения.
model LessonProgress {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  lessonId    String    @map("lesson_id")
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progresses")
}

// ╔══════════════════════════════════════════════════════════════╗
// ║             8. ASSIGNMENTS & TESTS  (5 таблиц)              ║
// ╚══════════════════════════════════════════════════════════════╝

/// Задание к уроку.
model Assignment {
  id          String         @id @default(uuid())
  lessonId    String         @map("lesson_id")
  title       String
  description String?
  type        AssignmentType
  maxScore    Int            @default(100) @map("max_score")
  isRequired  Boolean        @default(false) @map("is_required")
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  lesson      Lesson                @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions   TestQuestion[]
  submissions AssignmentSubmission[]

  @@index([lessonId])
  @@map("assignments")
}

/// Вопрос теста. Assignment(type=TEST) → N вопросов.
model TestQuestion {
  id            String  @id @default(uuid())
  assignmentId  String  @map("assignment_id")
  text          String
  explanation   String?
  isMultiSelect Boolean @default(false) @map("is_multi_select")
  sortOrder     Int     @default(0) @map("sort_order")

  assignment Assignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  options    TestOption[]

  @@index([assignmentId])
  @@map("test_questions")
}

/// Вариант ответа.
model TestOption {
  id         String  @id @default(uuid())
  questionId String  @map("question_id")
  text       String
  isCorrect  Boolean @default(false) @map("is_correct")
  sortOrder  Int     @default(0) @map("sort_order")

  question TestQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("test_options")
}

/// Ответ студента.
///
/// AI-проверка и финальная проверка РАЗДЕЛЕНЫ:
///   ai_*    → автоматическая предпроверка (ИИ)
///   final_* → ручная проверка (админ)
/// Эти два набора полей НЕ смешиваются.
/// Для тестов: final_score вычисляется автоматически, reviewed_by = NULL.
model AssignmentSubmission {
  id           String           @id @default(uuid())
  userId       String           @map("user_id")
  assignmentId String           @map("assignment_id")
  status       SubmissionStatus @default(PENDING)

  // Ответ студента
  textAnswer  String? @map("text_answer")
  testAnswers Json?   @map("test_answers") // [{questionId, selectedOptionIds:[]}]

  // AI pre-review
  aiScore      Int?              @map("ai_score")
  aiComment    String?           @map("ai_comment")
  aiCriteria   Json?             @map("ai_criteria") // [{criterion, score, maxScore, comment}]
  aiConfidence AiConfidenceLevel? @map("ai_confidence")
  aiReviewedAt DateTime?         @map("ai_reviewed_at")

  // Final review (admin or auto for tests)
  finalScore   Int?      @map("final_score")
  finalComment String?   @map("final_comment")
  reviewedBy   String?   @map("reviewed_by")
  reviewedAt   DateTime? @map("reviewed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignment Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  files      SubmissionFile[]

  @@index([userId])
  @@index([assignmentId])
  @@index([status])
  @@map("assignment_submissions")
}

/// Файл студента к заданию.
model SubmissionFile {
  id           String   @id @default(uuid())
  submissionId String   @map("submission_id")
  fileName     String   @map("file_name")
  filePath     String   @map("file_path")
  fileSize     Int?     @map("file_size")
  mimeType     String?  @map("mime_type")
  createdAt    DateTime @default(now()) @map("created_at")

  submission AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("submission_files")
}

