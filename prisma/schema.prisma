model AutoWebinarMaterial {
  id            String   @id @default(uuid())
  autoWebinarId String   @map("auto_webinar_id")
  title         String
  filePath      String   @map("file_path")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  autoWebinar AutoWebinar @relation(fields: [autoWebinarId], references: [id], onDelete: Cascade)

  @@index([autoWebinarId])
  @@map("auto_webinar_materials")
}

// ╔══════════════════════════════════════════════════════════════╗
// ║                     13. AI  (4 таблицы)                     ║
// ╚══════════════════════════════════════════════════════════════╝

/// Сессия AI-чата. courseId = контекст для RAG-retrieval.
/// MVP: courseId достаточно — AI отвечает в рамках материалов курса.
/// NULL courseId = общий чат без привязки к курсу.
/// Lesson-level контекст — post-MVP (добавить lessonId опционально).
model AiChatSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  courseId   String?  @map("course_id")
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course?         @relation(fields: [courseId], references: [id])
  messages AiChatMessage[]

  @@index([userId])
  @@map("ai_chat_sessions")
}

/// AI-сообщение. sources + confidence — только для role=ASSISTANT.
model AiChatMessage {
  id         String             @id @default(uuid())
  sessionId  String             @map("session_id")
  role       AiMessageRole
  content    String
  sources    Json?
  confidence AiConfidenceLevel?
  tokens     Int?
  createdAt  DateTime           @default(now()) @map("created_at")

  session AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("ai_chat_messages")
}

/// AI-лимиты. dailyLimit/monthlyLimit из TariffFeature.config.
model AiUsageLimit {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  dailyRequests    Int      @default(0) @map("daily_requests")
  monthlyRequests  Int      @default(0) @map("monthly_requests")
  dailyLimit       Int      @default(10) @map("daily_limit")
  monthlyLimit     Int      @default(100) @map("monthly_limit")
  lastResetDaily   DateTime @default(now()) @map("last_reset_daily")
  lastResetMonthly DateTime @default(now()) @map("last_reset_monthly")

  @@map("ai_usage_limits")
}

/// RAG-chunk. Vector column добавляется raw SQL.
model AiEmbedding {
  id         String                @id @default(uuid())
  sourceType AiEmbeddingSourceType @map("source_type")
  sourceId   String                @map("source_id")
  chunkIndex Int                   @map("chunk_index")
  content    String
  title      String?
  createdAt  DateTime              @default(now()) @map("created_at")

  @@index([sourceType, sourceId])
  @@map("ai_embeddings")
}

// ╔══════════════════════════════════════════════════════════════╗
// ║                14. NOTIFICATIONS  (1 таблица)               ║
// ╚══════════════════════════════════════════════════════════════╝

/// Уведомление. Одна строка = один канал.
/// eventKey группирует строки одного события (IN_APP + EMAIL + TG).
///
/// Lifecycle по каналам:
///   IN_APP:   PENDING → SENT (отображено в UI) → READ (user открыл). readAt заполняется.
///   EMAIL:    PENDING → SENT (SMTP accepted) | FAILED. readAt ВСЕГДА NULL (email opens ≠ reliable).
///   TELEGRAM: PENDING → SENT (API accepted) | FAILED. readAt NULL для MVP.
/// sentAt — момент успешной доставки провайдеру.
/// failedAt + errorMessage — при ошибке. Retry: status → PENDING, failedAt сохраняется.
model Notification {
  id                String             @id @default(uuid())
  userId            String             @map("user_id")
  type              NotificationType
  channel           NotificationChannel
  status            NotificationStatus @default(PENDING)
  eventKey          String?            @map("event_key")
  title             String
  body              String
  metadata          Json?
  providerMessageId String?            @map("provider_message_id")
  sentAt            DateTime?          @map("sent_at")
  readAt            DateTime?          @map("read_at")
  failedAt          DateTime?          @map("failed_at")
  errorMessage      String?            @map("error_message")
  createdAt         DateTime           @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, channel, status])
  @@index([eventKey])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

// ╔══════════════════════════════════════════════════════════════╗
// ║               15. PARTNER SYSTEM  (3 таблицы)               ║
// ╚══════════════════════════════════════════════════════════════╝

/// Партнёрский профиль.
/// SOURCE OF TRUTH для партнёрского статуса: is_approved.
/// User.isPartner УДАЛЁН — вычисляется из этой таблицы.
model PartnerProfile {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  referralCode   String   @unique @map("referral_code")
  commissionRate Decimal  @default(10) @db.Decimal(5, 2) @map("commission_rate")
  totalEarnings  Decimal  @default(0) @db.Decimal(12, 2) @map("total_earnings")
  pendingPayout  Decimal  @default(0) @db.Decimal(12, 2) @map("pending_payout")
  isApproved     Boolean  @default(false) @map("is_approved")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals   PartnerReferral[]
  commissions PartnerCommission[]

  @@map("partner_profiles")
}

/// Реферальное событие.
/// SOURCE OF TRUTH для "кто привёл пользователя" (event=REGISTRATION).
/// User.referredById УДАЛЁН — информация здесь.
/// Partial unique index на referred_user_id WHERE event='REGISTRATION' — raw SQL.
model PartnerReferral {
  id               String           @id @default(uuid())
  partnerProfileId String           @map("partner_profile_id")
  referredUserId   String           @map("referred_user_id")
  event            PartnerEventType
  createdAt        DateTime         @default(now()) @map("created_at")

  partnerProfile PartnerProfile @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  referredUser   User           @relation("ReferredUser", fields: [referredUserId], references: [id])

  @@index([partnerProfileId])
  @@index([referredUserId])
  @@map("partner_referrals")
}

/// Комиссия партнёра. commission_rate/purchase_amount — snapshot.
model PartnerCommission {
  id               String           @id @default(uuid())
  partnerProfileId String           @map("partner_profile_id")
  purchaseId       String           @map("purchase_id")
  referredUserId   String           @map("referred_user_id")
  purchaseAmount   Decimal          @db.Decimal(10, 2) @map("purchase_amount")
  commissionRate   Decimal          @db.Decimal(5, 2) @map("commission_rate")
  commissionAmount Decimal          @db.Decimal(10, 2) @map("commission_amount")
  status           CommissionStatus @default(PENDING)
  paidAt           DateTime?        @map("paid_at")
  createdAt        DateTime         @default(now()) @map("created_at")

  partnerProfile PartnerProfile @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  purchase       Purchase       @relation(fields: [purchaseId], references: [id])

  @@index([partnerProfileId])
  @@index([purchaseId])
  @@index([status])
  @@map("partner_commissions")
}

// ╔══════════════════════════════════════════════════════════════╗
// ║                  16. AUDIT LOG  (1 таблица)                 ║
// ╚══════════════════════════════════════════════════════════════╝

/// Лог бизнес-действий администратора. Append-only.
/// previous_data / new_data — snapshot ИЗМЕНЁННЫХ полей.
model AuditLog {
  id           String   @id @default(uuid())
  actorId      String   @map("actor_id")
  actorRole    UserRole @map("actor_role")
  action       String
  targetType   String   @map("target_type")
  targetId     String?  @map("target_id")
  details      Json?
  previousData Json?    @map("previous_data")
  newData      Json?    @map("new_data")
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
