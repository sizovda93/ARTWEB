model AutoWebinarSchedule {
  id            String   @id @default(uuid())
  autoWebinarId String   @map("auto_webinar_id")
  scheduledAt   DateTime @map("scheduled_at")
  isActive      Boolean  @default(true) @map("is_active")

  autoWebinar AutoWebinar @relation(fields: [autoWebinarId], references: [id], onDelete: Cascade)

  @@index([autoWebinarId])
  @@index([scheduledAt, isActive])
