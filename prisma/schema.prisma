// ╔══════════════════════════════════════════════════════════════╗
// ║              10. KNOWLEDGE BASE  (2 таблицы)                ║
// ╚══════════════════════════════════════════════════════════════╝

/// Элемент базы знаний.
/// Доступ: AccessGrant(KNOWLEDGE_BASE) + tier >= minTariffTier.
/// filePath / videoPath — основной файл / видео.
/// Доп. файлы — knowledge_item_attachments.
model KnowledgeItem {
  id            String            @id @default(uuid())
  title         String
  slug          String            @unique
  type          KnowledgeItemType
  description   String?
  content       String?
  filePath      String?           @map("file_path")
  videoPath     String?           @map("video_path")
  category      String?
  tags          String[]
  isPublished   Boolean           @default(false) @map("is_published")
  minTariffTier TariffTier        @default(BASIC) @map("min_tariff_tier")
  viewCount     Int               @default(0) @map("view_count")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  attachments KnowledgeItemAttachment[]

  @@index([category])
  @@index([type])
  @@index([isPublished])
  @@map("knowledge_items")
}

/// Дополнительный файл к элементу базы знаний.
/// Обоснование: юридический контент часто требует нескольких связанных файлов
/// (шаблон + заполненный пример + инструкция).
model KnowledgeItemAttachment {
  id              String   @id @default(uuid())
  knowledgeItemId String   @map("knowledge_item_id")
  fileName        String   @map("file_name")
  filePath        String   @map("file_path")
  fileSize        Int?     @map("file_size")
  mimeType        String?  @map("mime_type")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  knowledgeItem KnowledgeItem @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)

  @@index([knowledgeItemId])
  @@map("knowledge_item_attachments")
}

// ╔══════════════════════════════════════════════════════════════╗
// ║                  11. WEBINARS  (4 таблицы)                  ║
// ╚══════════════════════════════════════════════════════════════╝

/// Живой вебинар. Доступ: courseId (→ AccessGrant на курс) или isPublic.
model Webinar {
  id            String        @id @default(uuid())
  title         String
  slug          String        @unique
  description   String?
  coverPath     String?       @map("cover_path")
  courseId       String?       @map("course_id")
  status        WebinarStatus @default(SCHEDULED)
  scheduledAt   DateTime      @map("scheduled_at")
  startedAt     DateTime?     @map("started_at")
  endedAt       DateTime?     @map("ended_at")
  streamUrl     String?       @map("stream_url")
  recordingPath String?       @map("recording_path")
  maxAttendees  Int?          @map("max_attendees")
  isPublic      Boolean       @default(false) @map("is_public")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  course       Course?              @relation(fields: [courseId], references: [id])
  attendances  WebinarAttendance[]
  chatMessages WebinarChatMessage[]
  materials    WebinarMaterial[]

  @@index([status])
  @@index([scheduledAt])
  @@index([courseId])
  @@map("webinars")
}

model WebinarAttendance {
  id        String    @id @default(uuid())
  webinarId String    @map("webinar_id")
  userId    String    @map("user_id")
  joinedAt  DateTime  @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")

  webinar Webinar @relation(fields: [webinarId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([webinarId])
  @@index([userId])
  @@map("webinar_attendances")
}

model WebinarChatMessage {
  id        String   @id @default(uuid())
  webinarId String   @map("webinar_id")
  userId    String   @map("user_id")
  message   String
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")

  webinar Webinar @relation(fields: [webinarId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([webinarId, createdAt])
  @@map("webinar_chat_messages")
}

model WebinarMaterial {
  id        String   @id @default(uuid())
  webinarId String   @map("webinar_id")
  title     String
  filePath  String   @map("file_path")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  webinar Webinar @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@index([webinarId])
  @@map("webinar_materials")
}

// ╔══════════════════════════════════════════════════════════════╗
// ║                12. AUTO-WEBINARS  (4 таблицы)               ║
// ╚══════════════════════════════════════════════════════════════╝

model AutoWebinar {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  description   String?
  coverPath     String?  @map("cover_path")
  courseId       String?  @map("course_id")
  videoPath     String   @map("video_path")
  videoDuration Int?     @map("video_duration")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  course    Course?                @relation(fields: [courseId], references: [id])
  schedules AutoWebinarSchedule[]
  views     AutoWebinarView[]
  materials AutoWebinarMaterial[]

  @@index([courseId])
  @@map("auto_webinars")
