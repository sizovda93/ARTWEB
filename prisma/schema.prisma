generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm, uuid_ossp(map: "uuid-ossp"), vector(schema: "public")]
}

/// Пользователь: identity + профиль.
///
/// isPartner УДАЛЁН — source of truth: partner_profiles.is_approved.
/// referred_by_id УДАЛЁН — source of truth: partner_referrals (event=REGISTRATION).
/// В JWT isPartner вычисляется при логине из partner_profiles.
model User {
  id                    String                 @id @default(uuid())
  email                 String                 @unique
  passwordHash          String                 @map("password_hash")
  firstName             String                 @map("first_name")
  lastName              String                 @map("last_name")
  phone                 String?
  role                  UserRole               @default(STUDENT)
  isActive              Boolean                @default(true) @map("is_active")
  emailVerified         Boolean                @default(false) @map("email_verified")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  avatarPath            String?                @map("avatar_path")
  accessGrants          AccessGrant[]
  aiChatSessions        AiChatSession[]
  assignmentSubmissions AssignmentSubmission[]
  autoWebinarViews      AutoWebinarView[]
  courseProgresses      CourseProgress[]
  emailTokens           EmailToken[]
  lessonProgresses      LessonProgress[]
  notifications         Notification[]
  partnerProfile        PartnerProfile?
  referredByEntries     PartnerReferral[]      @relation("ReferredUser")
  sessions              Session[]
  telegramLink          TelegramLink?
  webinarAttendances    WebinarAttendance[]
  webinarMessages       WebinarChatMessage[]

  @@map("users")
}

model Session {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  userAgent   String?  @map("user_agent")
  ipAddress   String?  @map("ip_address")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  tokenDigest String   @unique @map("token_digest")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model EmailToken {
  id          String         @id @default(uuid())
  userId      String         @map("user_id")
  type        EmailTokenType
  expiresAt   DateTime       @map("expires_at")
  usedAt      DateTime?      @map("used_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  tokenDigest String         @unique @map("token_digest")
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("email_tokens")
}

model TelegramLink {
  id       String   @id @default(uuid())
  userId   String   @unique @map("user_id")
  chatId   String   @unique @map("chat_id")
  username String?
  isActive Boolean  @default(true) @map("is_active")
  linkedAt DateTime @default(now()) @map("linked_at")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_links")
}

model SecurityLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("security_logs")
}

/// Центральная сущность access-first модели.
///
/// Гранулярность:
/// COURSE         → resource_id = courseId (required)
/// KNOWLEDGE_BASE → resource_id = NULL
/// AI_CHAT        → resource_id = NULL
///
/// tier: заполняется для KNOWLEDGE_BASE (tier-based KB filtering).
/// Для COURSE и AI_CHAT — NULL.
model AccessGrant {
  id              String             @id @default(uuid())
  userId          String             @map("user_id")
  resourceType    AccessResourceType @map("resource_type")
  resourceId      String?            @map("resource_id")
  grantedVia      AccessGrantSource  @map("granted_via")
  grantedByUserId String?            @map("granted_by_user_id")
  tier            AccessTier?
  expiresAt       DateTime?          @map("expires_at")
  isActive        Boolean            @default(true) @map("is_active")
  revokedAt       DateTime?          @map("revoked_at")
  revokedBy       String?            @map("revoked_by")
  createdAt       DateTime           @default(now()) @map("created_at")
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, resourceType, resourceId, isActive])
  @@index([userId, resourceType, isActive])
  @@index([expiresAt])
  @@map("access_grants")
}

/// Курс. Доступ через AccessGrant(COURSE, courseId).
model Course {
  id               String           @id @default(uuid())
  title            String
  slug             String           @unique
  description      String?
  isPublished      Boolean          @default(false) @map("is_published")
  sortOrder        Int              @default(0) @map("sort_order")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  coverPath        String?          @map("cover_path")
  aiChatSessions   AiChatSession[]
  autoWebinars     AutoWebinar[]
  courseProgresses CourseProgress[]
  modules          Module[]
  webinars         Webinar[]

  @@map("courses")
}

model Module {
  id        String   @id @default(uuid())
  courseId  String   @map("course_id")
  title     String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  lessons   Lesson[]
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@map("modules")
}

model Lesson {
  id                 String           @id @default(uuid())
  moduleId           String           @map("module_id")
  title              String
  type               LessonType       @default(MIXED)
  content            String?
  videoDuration      Int?             @map("video_duration")
  isFree             Boolean          @default(false) @map("is_free")
  sortOrder          Int              @default(0) @map("sort_order")
  requiresAssignment Boolean          @default(false) @map("requires_assignment")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  videoPath          String?          @map("video_path")
  assignments        Assignment[]
  checklists         Checklist[]
  files              LessonFile[]
  lessonProgresses   LessonProgress[]
  module             Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@map("lessons")
}

model LessonFile {
  id        String   @id @default(uuid())
  lessonId  String   @map("lesson_id")
  fileName  String   @map("file_name")
  fileSize  Int?     @map("file_size")
  mimeType  String?  @map("mime_type")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  filePath  String   @map("file_path")
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("lesson_files")
}

model CourseProgress {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  courseId            String    @map("course_id")
  completedLessons   Int       @default(0) @map("completed_lessons")
  totalLessons       Int       @default(0) @map("total_lessons")
  progressPercent    Float     @default(0) @map("progress_percent")
  completedAt        DateTime? @map("completed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  lastRecalculatedAt DateTime  @default(now()) @map("last_recalculated_at")
  course             Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("course_progresses")
}

model LessonProgress {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  lessonId    String    @map("lesson_id")
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("lesson_progresses")
}

model Assignment {
  id          String                 @id @default(uuid())
  lessonId    String                 @map("lesson_id")
  title       String
  description String?
  type        AssignmentType
  maxScore    Int                    @default(100) @map("max_score")
  isRequired  Boolean                @default(false) @map("is_required")
  sortOrder   Int                    @default(0) @map("sort_order")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  submissions AssignmentSubmission[]
  lesson      Lesson                 @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions   TestQuestion[]

  @@index([lessonId])
  @@map("assignments")
}

model TestQuestion {
  id            String       @id @default(uuid())
  assignmentId  String       @map("assignment_id")
  text          String
  explanation   String?
  isMultiSelect Boolean      @default(false) @map("is_multi_select")
  sortOrder     Int          @default(0) @map("sort_order")
  options       TestOption[]
  assignment    Assignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@map("test_questions")
}

model TestOption {
  id         String       @id @default(uuid())
  text       String
  isCorrect  Boolean      @default(false) @map("is_correct")
  sortOrder  Int          @default(0) @map("sort_order")
  questionId String       @map("question_id")
  question   TestQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("test_options")
}

model AssignmentSubmission {
  id           String             @id @default(uuid())
  userId       String             @map("user_id")
  assignmentId String             @map("assignment_id")
  status       SubmissionStatus   @default(PENDING)
  textAnswer   String?            @map("text_answer")
  aiScore      Int?               @map("ai_score")
  aiComment    String?            @map("ai_comment")
  reviewedAt   DateTime?          @map("reviewed_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  aiConfidence AiConfidenceLevel? @map("ai_confidence")
  aiCriteria   Json?              @map("ai_criteria")
  aiReviewedAt DateTime?          @map("ai_reviewed_at")
  finalComment String?            @map("final_comment")
  finalScore   Int?               @map("final_score")
  reviewedBy   String?            @map("reviewed_by")
  testAnswers  Json?              @map("test_answers")
  assignment   Assignment         @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  files        SubmissionFile[]

  @@index([userId])
  @@index([assignmentId])
  @@index([status])
  @@map("assignment_submissions")
}

model SubmissionFile {
  id           String               @id @default(uuid())
  submissionId String               @map("submission_id")
  fileName     String               @map("file_name")
  filePath     String               @map("file_path")
  fileSize     Int?                 @map("file_size")
  mimeType     String?              @map("mime_type")
  createdAt    DateTime             @default(now()) @map("created_at")
  submission   AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("submission_files")
}

model Checklist {
  id        String          @id @default(uuid())
  lessonId  String          @map("lesson_id")
  title     String
  sortOrder Int             @default(0) @map("sort_order")
  items     ChecklistItem[]
  lesson    Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("checklists")
}

model ChecklistItem {
  id          String    @id @default(uuid())
  checklistId String    @map("checklist_id")
  text        String
  sortOrder   Int       @default(0) @map("sort_order")
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
  @@map("checklist_items")
}

/// Элемент базы знаний.
/// Доступ: AccessGrant(KNOWLEDGE_BASE) + tier >= minAccessTier.
model KnowledgeItem {
  id             String                    @id @default(uuid())
  title          String
  slug           String                    @unique
  type           KnowledgeItemType
  description    String?
  content        String?
  category       String?
  tags           String[]
  isPublished    Boolean                   @default(false) @map("is_published")
  minAccessTier  AccessTier                @default(BASIC) @map("min_access_tier")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")
  filePath       String?                   @map("file_path")
  videoPath      String?                   @map("video_path")
  viewCount      Int                       @default(0) @map("view_count")
  attachments    KnowledgeItemAttachment[]

  @@index([category])
  @@index([type])
  @@index([isPublished])
  @@map("knowledge_items")
}

model KnowledgeItemAttachment {
  id              String        @id @default(uuid())
  knowledgeItemId String        @map("knowledge_item_id")
  fileName        String        @map("file_name")
  filePath        String        @map("file_path")
  fileSize        Int?          @map("file_size")
  mimeType        String?       @map("mime_type")
  sortOrder       Int           @default(0) @map("sort_order")
  createdAt       DateTime      @default(now()) @map("created_at")
  knowledgeItem   KnowledgeItem @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)

  @@index([knowledgeItemId])
  @@map("knowledge_item_attachments")
}

model Webinar {
  id            String               @id @default(uuid())
  title         String
  slug          String               @unique
  description   String?
  status        WebinarStatus        @default(SCHEDULED)
  scheduledAt   DateTime             @map("scheduled_at")
  startedAt     DateTime?            @map("started_at")
  endedAt       DateTime?            @map("ended_at")
  streamUrl     String?              @map("stream_url")
  maxAttendees  Int?                 @map("max_attendees")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  courseId      String?              @map("course_id")
  coverPath     String?              @map("cover_path")
  isPublic      Boolean              @default(false) @map("is_public")
  recordingPath String?              @map("recording_path")
  attendances   WebinarAttendance[]
  chatMessages  WebinarChatMessage[]
  materials     WebinarMaterial[]
  course        Course?              @relation(fields: [courseId], references: [id])

  @@index([status])
  @@index([scheduledAt])
  @@index([courseId])
  @@map("webinars")
}

model WebinarAttendance {
  id        String    @id @default(uuid())
  webinarId String    @map("webinar_id")
  userId    String    @map("user_id")
  joinedAt  DateTime  @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  webinar   Webinar   @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@index([webinarId])
  @@index([userId])
  @@map("webinar_attendances")
}

model WebinarChatMessage {
  id        String   @id @default(uuid())
  webinarId String   @map("webinar_id")
  userId    String   @map("user_id")
  message   String
  createdAt DateTime @default(now()) @map("created_at")
  isDeleted Boolean  @default(false) @map("is_deleted")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  webinar   Webinar  @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@index([webinarId, createdAt])
  @@map("webinar_chat_messages")
}

model WebinarMaterial {
  id        String   @id @default(uuid())
  webinarId String   @map("webinar_id")
  title     String
  filePath  String   @map("file_path")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  webinar   Webinar  @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@index([webinarId])
  @@map("webinar_materials")
}

model AutoWebinar {
  id            String                @id @default(uuid())
  title         String
  slug          String                @unique
  description   String?
  videoDuration Int?                  @map("video_duration")
  isActive      Boolean               @default(true) @map("is_active")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  courseId      String?               @map("course_id")
  coverPath     String?               @map("cover_path")
  videoPath     String                @map("video_path")
  materials     AutoWebinarMaterial[]
  schedules     AutoWebinarSchedule[]
  views         AutoWebinarView[]
  course        Course?               @relation(fields: [courseId], references: [id])

  @@index([courseId])
  @@map("auto_webinars")
}

model AutoWebinarSchedule {
  id            String      @id @default(uuid())
  autoWebinarId String      @map("auto_webinar_id")
  scheduledAt   DateTime    @map("scheduled_at")
  isActive      Boolean     @default(true) @map("is_active")
  autoWebinar   AutoWebinar @relation(fields: [autoWebinarId], references: [id], onDelete: Cascade)

  @@index([autoWebinarId])
  @@index([scheduledAt, isActive])
  @@map("auto_webinar_schedules")
}

model AutoWebinarView {
  id            String      @id @default(uuid())
  autoWebinarId String      @map("auto_webinar_id")
  userId        String      @map("user_id")
  scheduleId    String?     @map("schedule_id")
  watchedAt     DateTime    @default(now()) @map("watched_at")
  watchDuration Int?        @map("watch_duration")
  autoWebinar   AutoWebinar @relation(fields: [autoWebinarId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([autoWebinarId])
  @@index([userId])
  @@map("auto_webinar_views")
}

model AutoWebinarMaterial {
  id            String      @id @default(uuid())
  autoWebinarId String      @map("auto_webinar_id")
  title         String
  sortOrder     Int         @default(0) @map("sort_order")
  createdAt     DateTime    @default(now()) @map("created_at")
  filePath      String      @map("file_path")
  autoWebinar   AutoWebinar @relation(fields: [autoWebinarId], references: [id], onDelete: Cascade)

  @@index([autoWebinarId])
  @@map("auto_webinar_materials")
}

model AiChatSession {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  courseId  String?         @map("course_id")
  title     String?
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  messages  AiChatMessage[]
  course    Course?         @relation(fields: [courseId], references: [id])
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ai_chat_sessions")
}

model AiChatMessage {
  id         String             @id @default(uuid())
  sessionId  String             @map("session_id")
  role       AiMessageRole
  content    String
  tokens     Int?
  createdAt  DateTime           @default(now()) @map("created_at")
  confidence AiConfidenceLevel?
  sources    Json?
  session    AiChatSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("ai_chat_messages")
}

/// AI-лимиты per user.
/// Source of truth для rate limiting (не для доступа — доступ = AccessGrant).
/// При выдаче AI_CHAT grant лимиты устанавливаются/сбрасываются.
model AiUsageLimit {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  dailyRequests    Int      @default(0) @map("daily_requests")
  monthlyRequests  Int      @default(0) @map("monthly_requests")
  lastResetDaily   DateTime @default(now()) @map("last_reset_daily")
  lastResetMonthly DateTime @default(now()) @map("last_reset_monthly")
  dailyLimit       Int      @default(10) @map("daily_limit")
  monthlyLimit     Int      @default(100) @map("monthly_limit")

  @@map("ai_usage_limits")
}

model AiEmbedding {
  id         String                @id @default(uuid())
  sourceType AiEmbeddingSourceType @map("source_type")
  sourceId   String                @map("source_id")
  chunkIndex Int                   @map("chunk_index")
  content    String
  title      String?
  createdAt  DateTime              @default(now()) @map("created_at")

  @@index([sourceType, sourceId])
  @@map("ai_embeddings")
}

model Notification {
  id                String              @id @default(uuid())
  userId            String              @map("user_id")
  type              NotificationType
  channel           NotificationChannel
  title             String
  body              String
  metadata          Json?
  sentAt            DateTime?           @map("sent_at")
  readAt            DateTime?           @map("read_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  errorMessage      String?             @map("error_message")
  eventKey          String?             @map("event_key")
  failedAt          DateTime?           @map("failed_at")
  providerMessageId String?             @map("provider_message_id")
  status            NotificationStatus  @default(PENDING)
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, channel, status])
  @@index([eventKey])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

/// Партнёрский профиль.
/// totalEarnings / pendingPayout — deprecated (payment domain удалён).
model PartnerProfile {
  id             String            @id @default(uuid())
  userId         String            @unique @map("user_id")
  referralCode   String            @unique @map("referral_code")
  commissionRate Decimal           @default(10) @map("commission_rate") @db.Decimal(5, 2)
  totalEarnings  Decimal           @default(0) @map("total_earnings") @db.Decimal(12, 2)
  pendingPayout  Decimal           @default(0) @map("pending_payout") @db.Decimal(12, 2)
  isApproved     Boolean           @default(false) @map("is_approved")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals      PartnerReferral[]

  @@map("partner_profiles")
}

model PartnerReferral {
  id               String           @id @default(uuid())
  partnerProfileId String           @map("partner_profile_id")
  referredUserId   String           @map("referred_user_id")
  createdAt        DateTime         @default(now()) @map("created_at")
  event            PartnerEventType
  partnerProfile   PartnerProfile   @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  referredUser     User             @relation("ReferredUser", fields: [referredUserId], references: [id])

  @@index([partnerProfileId])
  @@index([referredUserId])
  @@map("partner_referrals")
}

model AuditLog {
  id           String   @id @default(uuid())
  actorId      String   @map("actor_id")
  actorRole    UserRole @map("actor_role")
  action       String
  targetType   String   @map("target_type")
  targetId     String?  @map("target_id")
  details      Json?
  previousData Json?    @map("previous_data")
  newData      Json?    @map("new_data")
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

enum UserRole {
  ADMIN
  STUDENT
}

enum EmailTokenType {
  VERIFICATION
  PASSWORD_RESET
}

enum AccessTier {
  BASIC
  STANDARD
